generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model License {
  id                    String          @id @default(cuid())
  licenseKey            String          @unique @map("license_key")
  customerEmail         String          @map("customer_email")
  plan                  String
  status                String          @default("active")
  hwid                  String?
  expiresAt             DateTime?       @map("expires_at")
  lifetime              Boolean         @default(false)
  stripeSessionId       String?         @unique @map("stripe_session_id")
  stripePaymentIntentId String?         @map("stripe_payment_intent_id")
  validationCount       Int             @default(0) @map("validation_count")
  downloadCount         Int             @default(0) @map("download_count")
  lastValidatedAt       DateTime?       @map("last_validated_at")
  lastDownloadedAt      DateTime?       @map("last_downloaded_at")
  notes                 String?
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")
  orders                Order[]
  validationLogs        ValidationLog[]
  downloadLogs          DownloadLog[]

  @@index([customerEmail])
  @@index([plan, status])
  @@index([hwid])
  @@index([expiresAt])
  @@map("licenses")
}

model Order {
  id                    String   @id @default(cuid())
  stripeSessionId       String   @unique @map("stripe_session_id")
  stripePaymentIntentId String?  @map("stripe_payment_intent_id")
  customerEmail         String   @map("customer_email")
  plan                  String
  amount                Int
  currency              String
  status                String
  mode                  String   @default("unknown")
  country               String?
  locale                String?
  notes                 String?
  licenseId             String?  @map("license_id")
  license               License? @relation(fields: [licenseId], references: [id])
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@index([customerEmail])
  @@index([plan, status])
  @@index([currency])
  @@index([mode])
  @@index([createdAt])
  @@map("orders")
}

model Customer {
  id              String    @id @default(cuid())
  email           String    @unique
  totalSpent      Int       @default(0) @map("total_spent")
  totalOrders     Int       @default(0) @map("total_orders")
  firstPurchaseAt DateTime? @map("first_purchase_at")
  lastPurchaseAt  DateTime? @map("last_purchase_at")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("customers")
}

model User {
  id                 String               @id @default(cuid())
  email              String               @unique
  emailNormalized    String?              @unique @map("email_normalized")
  passwordHash       String               @map("password_hash")
  stripeCustomerId   String?              @unique @map("stripe_customer_id")
  discordUserId      String?              @unique @map("discord_user_id")
  discordUsername    String?              @map("discord_username")
  discordEmail       String?              @map("discord_email")
  discordAvatarUrl   String?              @map("discord_avatar_url")
  robloxUsername     String?              @map("roblox_username")
  robloxUserId       String?              @map("roblox_user_id")
  robloxAvatarUrl    String?              @map("roblox_avatar_url")
  emailVerifiedAt    DateTime?            @map("email_verified_at")
  role               String               @default("user")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")
  sessions           UserSession[]
  resetTokens        PasswordResetToken[]
  purchases          Purchase[]
  oauthLinks         OAuthLink[]
  paymentSubmissions PaymentSubmission[]

  @@index([role])
  @@index([discordUserId])
  @@index([robloxUserId])
  @@map("users")
}

model OAuthLink {
  id                 String    @id @default(cuid())
  userId             String    @map("user_id")
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider           String
  providerSubject    String    @map("provider_subject")
  providerUsername   String?   @map("provider_username")
  providerEmail      String?   @map("provider_email")
  accessTokenCipher  String?   @map("access_token_cipher")
  refreshTokenCipher String?   @map("refresh_token_cipher")
  tokenExpiresAt     DateTime? @map("token_expires_at")
  scopes             String?
  metadata           Json?
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@unique([provider, providerSubject])
  @@index([userId])
  @@index([provider])
  @@map("oauth_links")
}

model PaymentSubmission {
  id              String    @id @default(cuid())
  userId          String?   @map("user_id")
  user            User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  type            String    @default("robux_manual")
  status          String    @default("pending")
  plan            String
  customerEmail   String?   @map("customer_email")
  discordUserId   String?   @map("discord_user_id")
  discordUsername String?   @map("discord_username")
  robloxUserId    String?   @map("roblox_user_id")
  robloxUsername  String?   @map("roblox_username")
  premiumPlus     Boolean?  @map("premium_plus")
  robuxAmount     Int?      @map("robux_amount")
  proofUrl        String?   @map("proof_url")
  proofText       String?   @map("proof_text")
  notes           String?
  reviewedBy      String?   @map("reviewed_by")
  reviewedAt      DateTime? @map("reviewed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@index([plan])
  @@index([discordUserId])
  @@index([robloxUsername])
  @@index([createdAt])
  @@map("payment_submissions")
}

model UserSession {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique @map("token_hash")
  expiresAt  DateTime @map("expires_at")
  lastUsedAt DateTime @default(now()) @map("last_used_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("user_sessions")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model Product {
  id              String         @id @default(cuid())
  stripeProductId String?        @unique @map("stripe_product_id")
  name            String
  description     String?
  category        String?
  image           String?
  active          Boolean        @default(true)
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  prices          ProductPrice[]
  purchases       Purchase[]

  @@index([active])
  @@index([category])
  @@map("products")
}

model ProductPrice {
  id            String   @id @default(cuid())
  productId     String   @map("product_id")
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  stripePriceId String?  @unique @map("stripe_price_id")
  amount        Int
  currency      String   @default("eur")
  active        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([productId, active])
  @@index([currency])
  @@map("prices")
}

model Purchase {
  id                      String   @id @default(cuid())
  userId                  String   @map("user_id")
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId               String   @map("product_id")
  product                 Product  @relation(fields: [productId], references: [id])
  stripeCheckoutSessionId String   @unique @map("stripe_checkout_session_id")
  stripePaymentIntentId   String?  @map("stripe_payment_intent_id")
  amountTotal             Int      @map("amount_total")
  currency                String
  status                  String
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([productId])
  @@index([status])
  @@index([createdAt])
  @@map("purchases")
}

model ValidationLog {
  id         String   @id @default(cuid())
  licenseId  String?  @map("license_id")
  license    License? @relation(fields: [licenseId], references: [id], onDelete: SetNull)
  licenseKey String   @map("license_key")
  result     String
  reason     String?
  hwidHash   String?  @map("hwid_hash")
  appVersion String?  @map("app_version")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([licenseId])
  @@index([licenseKey])
  @@index([result, reason])
  @@index([createdAt])
  @@map("validation_logs")
}

model DownloadLog {
  id         String   @id @default(cuid())
  licenseId  String?  @map("license_id")
  license    License? @relation(fields: [licenseId], references: [id], onDelete: SetNull)
  licenseKey String   @map("license_key")
  result     String
  reason     String?
  version    String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([licenseId])
  @@index([licenseKey])
  @@index([result, reason])
  @@index([createdAt])
  @@map("download_logs")
}

model WebhookEvent {
  id               String   @id @default(cuid())
  stripeEventId    String   @unique @map("stripe_event_id")
  type             String
  processed        Boolean  @default(false)
  errorMessage     String?  @map("error_message")
  relatedOrderId   String?  @map("related_order_id")
  relatedLicenseId String?  @map("related_license_id")
  metadata         Json?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([type])
  @@index([processed])
  @@index([createdAt])
  @@map("webhook_events")
}

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  targetType String?  @map("target_type")
  targetId   String?  @map("target_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("audit_logs")
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  type      String
  plan      String?
  amount    Int?
  currency  String?
  mode      String?
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([type])
  @@index([plan])
  @@index([createdAt])
  @@map("analytics_events")
}

model Coupon {
  id                    String    @id @default(cuid())
  stripeCouponId        String?   @map("stripe_coupon_id")
  stripePromotionCodeId String?   @map("stripe_promotion_code_id")
  code                  String    @unique
  percentOff            Int?      @map("percent_off")
  amountOff             Int?      @map("amount_off")
  currency              String?
  active                Boolean   @default(true)
  expiresAt             DateTime? @map("expires_at")
  maxRedemptions        Int?      @map("max_redemptions")
  notes                 String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@index([active])
  @@map("coupons")
}
